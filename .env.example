# Base URL of the PetCare API (include the /api/v1 prefix).
VITE_API_URL=http://localhost:8081/api/v1

# Socket.IO server origin (defaults to the API origin derived from VITE_API_URL).
# VITE_SOCKET_URL=http://localhost:8081

# ──────────────────────────────────────────────
# Firebase Cloud Messaging (web push) — OPTIONAL
# Leave blank to disable push; chat still works in real time via Socket.IO
# plus browser system notifications. Values come from your Firebase web app
# config + Cloud Messaging Web Push certificate (VAPID key).
# ──────────────────────────────────────────────
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_VAPID_KEY=

# WebRTC TURN server (OPTIONAL) — needed for calls between users behind strict
# NATs/firewalls. STUN (Google public) is used by default and covers most cases.
# VITE_TURN_URL=turn:your.turn.server:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
